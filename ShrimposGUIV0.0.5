-- =============================================
-- TELEPORTS TAB (only in Dandy's World)
-- =============================================
if TeleportsTab then
    local function teleportToGate(gateName)
        local elevatorsFolder = Workspace:FindFirstChild("Elevators")
        if not elevatorsFolder then
            notify("Error", "Elevators folder not found in Workspace")
            return
        end
        local gate = elevatorsFolder:FindFirstChild(gateName)
        if not gate then
            notify("Error", gateName .. " not found in Elevators folder")
            return
        end
        local gateCFrame = nil
        if gate:IsA("BasePart") then
            gateCFrame = gate.CFrame
        elseif gate:IsA("Model") then
            local primary = gate.PrimaryPart
            if primary then
                gateCFrame = primary.CFrame
            else
                local part = gate:FindFirstChildWhichIsA("BasePart")
                if part then
                    gateCFrame = part.CFrame
                end
            end
        end
        if not gateCFrame then
            notify("Error", gateName .. " has no valid CFrame")
            return
        end
        local char = LocalPlayer.Character
        if not char or not char.Parent then
            LocalPlayer.CharacterAdded:Wait()
            char = LocalPlayer.Character
        end
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then
            for i = 1, 5 do
                task.wait(0.1)
                hrp = char and char:FindFirstChild("HumanoidRootPart")
                if hrp then break end
            end
        end
        if not hrp then
            notify("Error", "Could not find HumanoidRootPart")
            return
        end
        local success, err = pcall(function()
            hrp.CFrame = gateCFrame + Vector3.new(0, 3, 0)
        end)
        if success then
            notify("Teleported", "You have been teleported to the elevator")
        else
            notify("Error", "Teleport failed: " .. tostring(err))
        end
    end

    TeleportsTab:Button({
        Title = "Elevator 1",
        Desc = "Teleports you to Left Elevator",
        Callback = function() teleportToGate("LeftGate") end,
    })
    TeleportsTab:Button({
        Title = "Elevator 2",
        Desc = "Teleports you to Right Elevator",
        Callback = function() teleportToGate("RightGate") end,
    })
    TeleportsTab:Button({
        Title = "Elevator 3",
        Desc = "Teleports you to The Center Elevator",
        Callback = function() teleportToGate("CenterGate") end,
    })
end

