    local function applyESP(model, twistedName, rarity)
        local greenTwisteds = { BobetteMonster=true, RudieMonster=true, GingerMonster=true, CoalMonster=true }
        local purpleTwisteds = { BassieMonster=true, CocoaMonster=true, EggsonMonster=true, FlyteMonster=true }
        local orangeTwisteds = { GourdyMonster=true, EclipseMonster=true, RibbecaMonster=true, SoulvesterMonster=true }
        local blackTwisteds = { DandyMonster=true, DyleMonster=true }
        local fillColor, outlineColor
        if blackTwisteds[twistedName] then
            fillColor = Color3.fromRGB(10,10,10); outlineColor = Color3.fromRGB(0,0,0)
        elseif greenTwisteds[twistedName] then
            fillColor = Color3.fromRGB(80,220,80); outlineColor = Color3.fromRGB(255,255,255)
        elseif purpleTwisteds[twistedName] then
            fillColor = Color3.fromRGB(180,80,255); outlineColor = Color3.fromRGB(255,255,255)
        elseif orangeTwisteds[twistedName] then
            fillColor = Color3.fromRGB(255,160,50); outlineColor = Color3.fromRGB(255,255,255)
        else
            fillColor = Color3.fromRGB(220,40,40); outlineColor = Color3.fromRGB(255,255,255)
        end
        local hl = Instance.new("Highlight")
        hl.FillColor = fillColor; hl.OutlineColor = outlineColor; hl.FillTransparency = 0.4; hl.OutlineTransparency = 0
        hl.Adornee = model; hl.Parent = model; table.insert(espObjects, hl)
        local rootPart = model:IsA("Model") and (model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")) or model
        if not rootPart then return end
        local bb = Instance.new("BillboardGui")
        bb.Adornee = rootPart; bb.AlwaysOnTop = true; bb.Size = UDim2.new(0,200,0,55); bb.StudsOffset = Vector3.new(0,5,0); bb.Parent = rootPart
        local displayName = (twistedName == "FakeCapsule") and "Fake Capsule" or twistedName:gsub("Monster","")
        local mainLabel = Instance.new("TextLabel")
        mainLabel.Size = UDim2.new(1,0,0.5,0); mainLabel.Position = UDim2.new(0,0,0,0); mainLabel.BackgroundTransparency = 1
        if twistedName == "FakeCapsule" then
            mainLabel.Text = "Fake Capsule"
        else
            mainLabel.Text = "Twisted " .. displayName .. " | " .. rarity
        end
        if twistedName == "FinnMonster" then mainLabel.TextColor3 = Color3.fromRGB(255,215,0) else mainLabel.TextColor3 = rarityTextColors[rarity] or Color3.new(1,1,1) end
        mainLabel.TextStrokeTransparency = 0; mainLabel.TextStrokeColor3 = Color3.new(0,0,0); mainLabel.Font = Enum.Font.GothamBold; mainLabel.TextSize = 11; mainLabel.TextScaled = false; mainLabel.Parent = bb
        local cooldownDuration = COOLDOWN_MONSTERS[twistedName]
        if cooldownDuration then
            local cooldownLabel = Instance.new("TextLabel")
            cooldownLabel.Size = UDim2.new(1,0,0.4,0); cooldownLabel.Position = UDim2.new(0,0,0.5,0); cooldownLabel.BackgroundTransparency = 1
            cooldownLabel.Text = "CD: Ready"; cooldownLabel.TextColor3 = Color3.fromRGB(80,255,80); cooldownLabel.TextStrokeTransparency = 0; cooldownLabel.TextStrokeColor3 = Color3.new(0,0,0)
            cooldownLabel.Font = Enum.Font.GothamBold; cooldownLabel.TextSize = 10; cooldownLabel.TextScaled = false; cooldownLabel.Parent = bb
            local key = model:GetFullName()
            if not cooldownTimers[key] then cooldownTimers[key] = { active = false, timeLeft = 0 } end
            local timer = cooldownTimers[key]
            local hum = model:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.HealthChanged:Connect(function()
                    if not timer.active then timer.active = true; timer.timeLeft = cooldownDuration end
                end)
            end
            local conn; conn = RunService.Heartbeat:Connect(function(dt)
                if not TwistedsESPEnabled or not bb.Parent then conn:Disconnect(); return end
                if timer.active then
                    timer.timeLeft = math.max(0, timer.timeLeft - dt)
                    if timer.timeLeft <= 0 then
                        timer.active = false
                        if cooldownLabel then cooldownLabel.Text = "CD: Ready"; cooldownLabel.TextColor3 = Color3.fromRGB(80,255,80) end
                    else
                        if cooldownLabel then cooldownLabel.Text = "CD: " .. string.format("%.1f", timer.timeLeft) .. "s"; cooldownLabel.TextColor3 = Color3.fromRGB(255,100,100) end
                    end
                else
                    if cooldownLabel and not timer.active then cooldownLabel.Text = "CD: Ready"; cooldownLabel.TextColor3 = Color3.fromRGB(80,255,80) end
                end
            end)
            table.insert(espObjects, conn)
        end
        table.insert(espObjects, bb)
    end

