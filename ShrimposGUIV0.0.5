    -- ANTI VEE POPUPS
    local antiVeePopupsEnabled = false
    local popupOriginalVisibility = {}

    local function hasProperty(object, propertyName)
        local success, _ = pcall(function()
            object[propertyName] = object[propertyName]
        end)
        return success
    end

    local function getScreengui()
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        if playerGui then
            return playerGui:FindFirstChild("ScreenGui")
        end
        return nil
    end

    local function applyAntiVeePopups(hide)
        local sg = getScreengui()
        if not sg then return end
        local popup = sg:FindFirstChild("PopUp")
        if not popup then return end
        for _, child in ipairs(popup:GetChildren()) do
            if hasProperty(child, "Visible") then
                if hide then
                    if popupOriginalVisibility[child] == nil then
                        popupOriginalVisibility[child] = child.Visible
                    end
                    child.Visible = false
                else
                    if popupOriginalVisibility[child] ~= nil then
                        child.Visible = popupOriginalVisibility[child]
                    else
                        child.Visible = true
                    end
                end
            end
        end
    end

    VisualsTab:Toggle({
        Title = "Anti Vee Popups",
        Desc = "Hides annoying popups (Vee) from the ScreenGui",
        Value = false,
        Callback = function(state)
            antiVeePopupsEnabled = state
            applyAntiVeePopups(state)
            if state then
                notify("Anti Vee Popups", "Popups hidden.")
            else
                notify("Anti Vee Popups", "Popups restored.")
            end
        end,
    })
