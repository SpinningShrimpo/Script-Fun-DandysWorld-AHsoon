    if skillCheckEvent then
        local ogcb = getcallbackvalue(skillCheckEvent, "OnClientInvoke")
        local ts = TweenService
        local ti = TweenInfo.new(1.5, Enum.EasingStyle.Linear)

        if ogcb then
            local hook
            hook = hookfunction(ogcb, function(...)
                if getgenv().scinstant then
                    task.spawn(function()
                        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
                        if not playerGui then return end
                        local screenGui = playerGui:FindFirstChild("ScreenGui")
                        if not screenGui then return end
                        local menu = screenGui:FindFirstChild("Menu")
                        if not menu then return end

                        local correctSound = menu:FindFirstChild("Correct")
                        if correctSound then
                            correctSound:Stop()
                            correctSound:Play()
                        end

                        local goldAreaHit = menu:FindFirstChild("GoldAreaHit")
                        if goldAreaHit then
                            goldAreaHit:Stop()
                            goldAreaHit:Play()
                        end

                        local msg = menu:FindFirstChild("SkillCheckMessage")
                        if msg then
                            local gradient = msg:FindFirstChild("UIGradient")
                            if gradient then gradient.Enabled = false end
                            msg.Text = "Great Job!"
                            local gradientWin = msg:FindFirstChild("UIGradientWin")
                            if gradientWin then gradientWin.Enabled = true end
                            msg.Visible = true
                        end

                        task.wait(1.5)

                        if msg then
                            local tween = ts:Create(msg, ti, { TextTransparency = 1 })
                            tween:Play()
                            tween.Completed:Wait()
                            msg.Visible = false
                            msg.TextTransparency = 0
                        end
                    end)
                    return "supercomplete"
                end
                return hook(...)
            end)
