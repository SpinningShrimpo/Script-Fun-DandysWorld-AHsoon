local antiLagEnabled = false
local antiLagConnection = nil

local function applyAntiLag(part)
    if part:IsA("BasePart") then
        part.Material = Enum.Material.SmoothPlastic
    elseif part:IsA("Decal") or part:IsA("Texture") then
        part:Destroy()
    end
end

local function enableAntiLag()
    if antiLagEnabled then return end
    antiLagEnabled = true
    for _, part in ipairs(Workspace:GetDescendants()) do
        applyAntiLag(part)
    end
    if not antiLagConnection then
        antiLagConnection = Workspace.DescendantAdded:Connect(applyAntiLag)
    end
    notify("Anti Lag", "Enabled. Materials changed and decals removed.")
end

local function disableAntiLag()
    antiLagEnabled = false
    if antiLagConnection then
        antiLagConnection:Disconnect()
        antiLagConnection = nil
    end
    notify("Anti Lag", "Disabled. Existing changes remain (cannot revert automatically).")
end

VisualsTab:Toggle({
    Title = "Anti Lag",
    Desc = "Changes materials to SmoothPlastic and removes decals/textures",
    Value = false,
    Callback = function(state)
        if state then
            enableAntiLag()
        else
            disableAntiLag()
        end
    end,
})

